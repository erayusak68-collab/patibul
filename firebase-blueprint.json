{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "gender": { "type": "string", "enum": ["Kadın", "Erkek", "Belirtilmedi"] },
        "petType": { "type": "string", "enum": ["Kedi", "Köpek"] },
        "inviteCode": { "type": "string" },
        "patiPuan": { "type": "number" },
        "profilePhoto": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "matches": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "fullName", "email", "city", "district", "gender", "petType", "inviteCode", "patiPuan", "role"]
    },
    "Pet": {
      "title": "Pet",
      "description": "Pet listing information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Kedi", "Köpek"] },
        "breed": { "type": "string" },
        "age": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "vaccinationStatus": { "type": "string" },
        "neuteredStatus": { "type": "string" },
        "energyLevel": { "type": "number" },
        "toiletTraining": { "type": "boolean" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerPhoto": { "type": "string" },
        "createdAt": { "type": "string" },
        "isBoosted": { "type": "boolean" },
        "boostedUntil": { "type": "string" }
      },
      "required": ["id", "name", "type", "breed", "age", "city", "district", "photos", "description", "ownerId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "audio"] },
        "dataUrl": { "type": "string" }
      },
      "required": ["id", "senderId", "timestamp", "type"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object", "additionalProperties": { "type": "string" } },
        "participantPhotos": { "type": "object", "additionalProperties": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string" },
        "petId": { "type": "string" },
        "unreadCount": { "type": "number" }
      },
      "required": ["id", "participants"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "pets/{petId}": {
      "schema": "Pet",
      "description": "Pet listings"
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    }
  }
}
